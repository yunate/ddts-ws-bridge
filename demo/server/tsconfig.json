{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "preserveSymlinks": true,
    "sourceMap": true
  },
  "include": [
    "src",
    "../common/validator.ts",
    "../common/protocol",
    "../common/ws_bridge/peer.ts",
    "../common/ws_bridge/wsServerPeer.ts",
    "../common/ws_bridge/rpc.ts"
  ]
}
